{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "deepseek/deepseek-v4-flash",
  "provider": {
    "openrouter": {
      "models": {
        "deepseek/deepseek-v4-flash": {
          "options": {
            "provider": {
              "only": ["deepseek"]
            }
          }
        },
        "deepseek/deepseek-v4-pro": {
          "options": {
            "provider": {
              "only": ["deepseek"]
            }
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": {
      "~/.cargo/registry/src/**": "allow"
    }
  }
}
