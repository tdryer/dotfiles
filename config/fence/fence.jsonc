{
  "allowPty": true,
  "network": {
    "allowedDomains": [
      "api.github.com",
      "pypi.org",
      "files.pythonhosted.org",
      "openrouter.ai",
      "index.crates.io",
      "static.crates.io",
      "static.rust-lang.org"
    ]
  },
  "filesystem": {
    "defaultDenyRead": true,
    "allowRead": [
      "~/.config/" // workaround for opencode
    ],
    "allowWrite": [
      "~/.cache/opencode/",
      "~/.config/opencode/",
      "~/.local/share/opencode/",
      "~/.local/state/opencode/",
      "~/.cache/uv/",
      "~/.local/share/uv/",
      "~/.cargo",
      "~/.rustup",
      "."
    ]
  }
}
